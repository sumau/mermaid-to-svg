# Shared configuration for render.sh and the CI workflow — the Mermaid folder
# layout and the pinned image are defined here once, then sourced by both.
#
# NOTE: the workflow's `on.push.paths` filter cannot read this file (GitHub
# evaluates it before the job starts), so those trigger globs are the one place
# that still names the folders, coarsely.

IMAGE="minlag/mermaid-cli:11.16.0"
SOURCE_DIR="mermaid/source"
OUTPUT_DIR="mermaid/generated"
TEMP_DIR=".mermaid-tmp"
CONFIG="mermaid/config.json"
